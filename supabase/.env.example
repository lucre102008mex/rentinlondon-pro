# =============================================================================
# RentInLondon PRO — Supabase Environment Variables
# Copia este archivo a .env y completa con tus valores reales
# NUNCA subas .env al repositorio
# =============================================================================

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_publica_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta_aqui

# ─── Google Service Account (para sync-to-sheets Edge Function) ───────────────
# Correo de la cuenta de servicio creada en Google Cloud Console
GOOGLE_SA_EMAIL=rentinlondon-sync@TU_PROYECTO.iam.gserviceaccount.com

# Clave privada RSA de la cuenta de servicio (en formato PEM, con \n literales)
# Obtener de: Google Cloud Console > IAM > Service Accounts > Keys > Add Key > JSON
GOOGLE_SA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----\n"

# ID de tu Google Spreadsheet (de la URL: /spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ─── Seguridad HMAC ───────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
WEBHOOK_HMAC_SECRET=reemplazar_con_openssl_rand_hex_32

# ─── Configuración general ────────────────────────────────────────────────────
TZ=Europe/London
NODE_ENV=production
