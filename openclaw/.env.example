# =============================================================================
# RentInLondon PRO — OpenClaw Gateway Environment Variables
# Copia este archivo a .env y completa con tus valores reales
# NUNCA subas .env al repositorio
# =============================================================================

# ─── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
NODE_ENV=production
TZ=Europe/London

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ─── WhatsApp Business API ────────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=tu_whatsapp_business_token
WHATSAPP_PHONE_ID=tu_phone_number_id
WHATSAPP_VERIFY_TOKEN=tu_verify_token_para_webhook

# ─── Telegram (para Alex) ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token
TELEGRAM_CHAT_ID=chat_id_del_dueno

# ─── HMAC (mismo que Supabase) ────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
HMAC_SECRET=reemplazar_con_openssl_rand_hex_32

# ─── Facebook/Instagram Ads ───────────────────────────────────────────────────
FB_PAGE_ACCESS_TOKEN=tu_facebook_page_access_token
FB_APP_ID=tu_facebook_app_id
FB_APP_SECRET=tu_facebook_app_secret
FB_WEBHOOK_VERIFY_TOKEN=tu_fb_webhook_verify_token

# ─── Gumtree API (si disponible) ─────────────────────────────────────────────
GUMTREE_API_KEY=tu_gumtree_api_key_si_aplica

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=/var/log/rentinlondon
LOG_FILE=agent.log

# ─── Alertas de costo (cost-guard) ───────────────────────────────────────────
DAILY_TOKEN_LIMIT=100000
DAILY_COST_LIMIT_GBP=50
