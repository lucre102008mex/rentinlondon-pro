# =============================================================================
# RentInLondon PRO — OpenClaw Gateway Environment Variables
# Copia este archivo a .env y completa con tus valores reales
# NUNCA subas .env al repositorio
# =============================================================================

# ─── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
NODE_ENV=production
TZ=Europe/London

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ─── WhatsApp (wacli / QR) ───────────────────────────────────────────────────
# WhatsApp se gestiona vía wacli (sesión QR escaneada en OpenClaw).
# No se usa la API oficial de Meta. No requiere tokens ni phone_id.

# Números de WhatsApp de las agentes (para alertas)
IVY_WHATSAPP_NUMBER=+447000000001
ROSE_WHATSAPP_NUMBER=+447000000002
SALO_WHATSAPP_NUMBER=+447000000003
JEANETTE_WHATSAPP_NUMBER=+447000000004

# WACLI CLI path (si está instalado)
WACLI_PATH=/usr/local/bin/wacli

# WhatsApp Business API (alternativo a wacli)
WHATSAPP_API_URL=https://api.twilio.com/2010-04-01/Accounts/{SID}/Messages.json
WHATSAPP_ACCOUNT_SID=tu_twilio_account_sid
WHATSAPP_AUTH_TOKEN=tu_twilio_auth_token
WHATSAPP_FROM_NUMBER=+447000000000

# ─── Telegram (para Alex) ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token
TELEGRAM_CHAT_ID=chat_id_del_dueno

# ─── HMAC (mismo que Supabase) ────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
HMAC_SECRET=reemplazar_con_openssl_rand_hex_32

# ─── Facebook/Instagram Ads (solo lectura de métricas) ────────────────────────
# Estas credenciales son para que ads-fb consulte rendimiento de campañas.
# NO se usan para capturar leads (los leads llegan por CTWA directo a WhatsApp).
FB_PAGE_ACCESS_TOKEN=tu_facebook_page_access_token
FB_APP_ID=tu_facebook_app_id
FB_APP_SECRET=tu_facebook_app_secret

# ─── Gumtree API (si disponible) ─────────────────────────────────────────────
GUMTREE_API_KEY=tu_gumtree_api_key_si_aplica

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=/var/log/rentinlondon
LOG_FILE=agent.log

# ─── Alertas de costo (cost-guard) ───────────────────────────────────────────
DAILY_TOKEN_LIMIT=100000
DAILY_COST_LIMIT_GBP=50
