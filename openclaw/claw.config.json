{
  "gateway": {
    "name": "rentinlondon-pro",
    "version": "1.0.0",
    "timezone": "Europe/London"
  },
  "bindings": [
    {
      "agent": "alex",
      "channel": "telegram",
      "hooks": {
        "on_message": "/home/ubuntu/.openclaw/workspace/agents/alex/IDENTITY.md",
        "on_schedule": "pipelines/daily-report.lobster",
        "on_error": "alert_owner"
      },
      "hmac": {
        "enabled": false,
        "comment": "Telegram usa su propio mecanismo de autenticación"
      }
    },
    {
      "agent": "ivy",
      "channel": "whatsapp",
      "hooks": {
        "on_message": "/home/ubuntu/.openclaw/workspace/agents/ivy/IDENTITY.md",
        "on_lead_created": "log_interaction",
        "on_escalate": "forward_to_jeanette"
      },
      "hmac": {
        "enabled": true,
        "header": "X-Signature",
        "algorithm": "sha256",
        "secret_env": "HMAC_SECRET"
      },
      "filters": {
        "es_internacional": false,
        "canal_origen": [
          "whatsapp"
        ]
      }
    },
    {
      "agent": "rose",
      "channel": "whatsapp",
      "hooks": {
        "on_message": "/home/ubuntu/.openclaw/workspace/agents/rose/IDENTITY.md",
        "on_lead_created": "log_interaction",
        "on_escalate": "forward_to_jeanette"
      },
      "hmac": {
        "enabled": true,
        "header": "X-Signature",
        "algorithm": "sha256",
        "secret_env": "HMAC_SECRET"
      },
      "filters": {
        "es_internacional": false,
        "canal_origen": [
          "facebook",
          "instagram"
        ]
      }
    },
    {
      "agent": "salo",
      "channel": "whatsapp",
      "hooks": {
        "on_message": "/home/ubuntu/.openclaw/workspace/agents/salo/IDENTITY.md",
        "on_lead_created": "log_interaction",
        "on_escalate": "forward_to_jeanette"
      },
      "hmac": {
        "enabled": true,
        "header": "X-Signature",
        "algorithm": "sha256",
        "secret_env": "HMAC_SECRET"
      },
      "filters": {
        "es_internacional": false,
        "canal_origen": [
          "gumtree",
          "rightmove",
          "zoopla",
          "spareroom",
          "openrent"
        ]
      }
    },
    {
      "agent": "jeanette",
      "channel": "whatsapp",
      "hooks": {
        "on_message": "/home/ubuntu/.openclaw/workspace/agents/jeanette/IDENTITY.md",
        "on_lead_escalated": "accept_escalation",
        "on_contract_signed": "notify_alex",
        "on_r2r_completed": "update_contract"
      },
      "hmac": {
        "enabled": true,
        "header": "X-Signature",
        "algorithm": "sha256",
        "secret_env": "HMAC_SECRET"
      },
      "filters": {
        "es_internacional_or_asignado": true
      }
    },
    {
      "agent": "facebook",
      "channel": "internal",
      "hooks": {
        "on_schedule": "generate_ads_report"
      },
      "comment": "ads-fb NO captura leads. Gestiona campañas FB/IG y reporta métricas. Los leads llegan directo a Rose/Ivy vía CTWA."
    },
    {
      "agent": "gumtree",
      "channel": "internal",
      "hooks": {
        "on_schedule_refresh": "refresh_all_listings",
        "on_schedule_report": "generate_listings_report"
      },
      "comment": "ads-gumtree NO captura leads. Gestiona listings en marketplaces. Los leads llegan directo a Salo vía WhatsApp desde el anuncio."
    },
    {
      "agent": "script",
      "channel": "internal",
      "hooks": {
        "on_schedule": "run_scheduled_task",
        "on_reactivation_prepared": "await_human_approval",
        "on_approval_received": "send_reactivation_messages"
      },
      "hmac": {
        "enabled": true,
        "header": "X-Internal-Signature",
        "algorithm": "sha256",
        "secret_env": "HMAC_SECRET"
      },
      "restrictions": {
        "no_external_channels": true,
        "requires_approval_for_send": true
      }
    }
  ],
  "global_hooks": {
    "before_any_action": "verify_hmac_if_external",
    "after_any_action": "log_to_agent_logs",
    "on_compliance_flag": "log_to_compliance_audit",
    "on_error": "alert_alex_via_telegram",
    "on_daily_limit_exceeded": "pause_agent_and_alert"
  },
  "sync_to_sheets": {
    "enabled": true,
    "edge_function_url": "${SUPABASE_URL}/functions/v1/sync-to-sheets",
    "hmac_secret_env": "HMAC_SECRET",
    "schedule": "0 */6 * * * Europe/London",
    "tables": [
      "leads",
      "interactions",
      "properties",
      "viewings",
      "contracts",
      "listings_history",
      "weekly_summaries"
    ]
  }
}